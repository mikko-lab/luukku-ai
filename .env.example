# Anthropic Claude API — used for PDF extraction
ANTHROPIC_API_KEY=sk-ant-...

# Postgres connection. _DIRECT is the non-pooled URL Prisma uses
# for migrations / db push. Both should point at the same database.
DATABASE_URL=postgresql://user:password@host:5432/luukku
DATABASE_URL_DIRECT=postgresql://user:password@host:5432/luukku

# Session JWT — must be at least 32 characters.
# Generate one with: openssl rand -base64 48
JWT_SECRET=replace_with_a_random_string_of_at_least_32_characters

# `true` in HTTPS production, `false` for local HTTP dev
COOKIE_SECURE=false

# Stripe — sk_test_… in dev, sk_live_… in production
STRIPE_SECRET_KEY=sk_test_replace_me
# Signing secret of the configured Stripe webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Resend — used to email the PDF report after a successful payment
RESEND_API_KEY=re_replace_me

# Public base URL of the app (Stripe success/cancel URLs reference this)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Upstash Redis — optional. When set, enables per-user rate limits
# on /api/auth/login, /api/auth/signup, /api/analyze and /api/report.
# Leave unset to disable rate limiting (dev convenience).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin endpoint shared secret — used by /api/admin/add-credits
# via the `x-admin-key` header
ADMIN_KEY=replace_with_a_random_admin_secret
